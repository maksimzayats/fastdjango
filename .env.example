# Compose
COMPOSE_PROJECT_NAME=modern-python-template
COMPOSE_FILE=docker/docker-compose.yaml:docker/docker-compose.local.yaml

# Application
ENVIRONMENT=local
LOGGING_LEVEL=DEBUG
VERSION=0.1.0
TIME_ZONE=UTC

# Secrets
JWT_SECRET_KEY=example-jwt-key-with-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_TYP=at+jwt
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_SESSION_REFRESH_TOKEN_NBYTES=32
REFRESH_SESSION_REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128

# HTTP
ALLOWED_HOSTS=["127.0.0.1","localhost","0.0.0.0"]
CORS_ALLOW_ORIGINS=["http://localhost"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
TRUST_FORWARDED_IP_HEADER=false
IP_HEADER=x-forwarded-for
USER_AGENT_HEADER=user-agent

# Observability
LOGFIRE_ENABLED=false
LOGFIRE_SERVICE_NAME=modern-python-template
LOGFIRE_SERVICE_VERSION=0.1.0
LOGFIRE_ENVIRONMENT=local
INSTRUMENTOR_FASTAPI_EXCLUDED_URLS=[".*/api/v1/health"]

# Database
POSTGRES_DB=modern_python_template
POSTGRES_PASSWORD=example-postgres-password
POSTGRES_PORT=5432
POSTGRES_USER=postgres
DATABASE_URL="postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}"
DATABASE_ECHO=false

# Redis
REDIS_PASSWORD=example-redis-password
REDIS_PORT=6379
REDIS_URL="redis://default:${REDIS_PASSWORD}@localhost:${REDIS_PORT}/0"
