# Application
ENVIRONMENT=test
LOGGING_LEVEL=DEBUG
VERSION=0.1.0
TIME_ZONE=UTC

# Secrets
JWT_SECRET_KEY=test-jwt-secret-key-with-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_TYP=at+jwt
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_SESSION_REFRESH_TOKEN_NBYTES=32
REFRESH_SESSION_REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128

# Observability
LOGFIRE_ENABLED=false
LOGFIRE_ENVIRONMENT=test
LOGFIRE_SERVICE_NAME=modern-python-template
LOGFIRE_SERVICE_VERSION=0.1.0
INSTRUMENTOR_FASTAPI_EXCLUDED_URLS=[".*/api/v1/health"]

# HTTP
TRUST_FORWARDED_IP_HEADER=false
IP_HEADER=x-forwarded-for
USER_AGENT_HEADER=user-agent

# Database
DATABASE_URL=sqlite+aiosqlite:///test_db.sqlite3
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
